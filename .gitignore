# ===========================
# SwMaster .gitignore
# ===========================

# ----- Environment & Secrets -----
.env
.env.*
!.env.example

# ----- Node.js -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
*.whl

# ----- IDE & Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ----- OS Files -----
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
._*

# Linux
*.directory

# ----- Next.js -----
.next/

# ----- Build & Output -----
*.log
logs/
coverage/
.nyc_output/
out/
tmp/
temp/

# ----- Docker -----
docker-compose.override.yml

# ----- Gemini / Antigravity Agent -----
.gemini/
